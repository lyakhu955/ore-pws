# Variabili ambiente necessarie per Vercel
# Copia questo file in .env.local per sviluppo locale
# Su Vercel, configura queste variabili nel dashboard

# Google OAuth Credentials
GOOGLE_CLIENT_ID=990017681774-kmghq0vajmb8lbv7gqv2qsi7fn1rbp4f.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Note:
# - GOOGLE_CLIENT_ID è già pubblico nel codice frontend
# - GOOGLE_CLIENT_SECRET deve essere configurato SOLO su Vercel (mai nel codice)
# - Su Vercel Dashboard: Settings > Environment Variables
